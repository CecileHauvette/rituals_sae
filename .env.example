# Google Cloud project and BigQuery dataset where raw and transformed data will be stored
GCP_PROJECT=your-gcp-project-id
BQ_DATASET=your-bigquery-dataset

# GitHub personal access token
# Generate one at: https://github.com/settings/tokens (no specific scopes needed for public repos)
GITHUB_TOKEN=ghp_your_token_here

# Load data updated after this date (ISO 8601 format)
# Used as the initial watermark — subsequent runs use the latest loaded timestamp
SINCE=2023-01-01
